# Hyperliquid Credentials
# Get from: https://hyperliquid.gitbook.io/hyperliquid-docs/for-developers/api/api-authenication
HL_ACCOUNT_ADDRESS=0x...
HL_PRIVATE_KEY=0x...

# Telegram Bot Credentials
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google AI (For News Sniper)
GEMINI_API_KEY=

# ============================================
# Production Settings (for Railway/Docker)
# ============================================

# Environment: development | production
ENVIRONMENT=development

# Redis URL (Railway will provide this automatically)
# For local Docker: redis://redis:6379/0
# For Railway: Use the REDIS_URL from Redis add-on
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (Railway will provide this automatically)
# For local Docker: postgresql://hypersentry:hypersentry_dev@postgres:5432/hypersentry
DATABASE_URL=

# CORS - Comma-separated list of allowed origins
# Add your frontend domain here for production
ALLOWED_ORIGINS=http://localhost:3000
